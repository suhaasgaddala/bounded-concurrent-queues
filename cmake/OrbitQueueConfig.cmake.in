@PACKAGE_INIT@

include("${CMAKE_CURRENT_LIST_DIR}/OrbitQueueTargets.cmake")

if(TARGET OrbitQueue::orbitqueue AND NOT TARGET BoundedConcurrentQueues::orbitqueue)
    add_library(BoundedConcurrentQueues::orbitqueue INTERFACE IMPORTED)
    set_target_properties(BoundedConcurrentQueues::orbitqueue PROPERTIES
        INTERFACE_LINK_LIBRARIES OrbitQueue::orbitqueue)
endif()

check_required_components(OrbitQueue)
